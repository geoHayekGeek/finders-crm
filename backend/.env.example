# Copy to .env and fill in values. Never commit .env.

# --- Database (use DATABASE_URL in production, or individual vars locally) ---
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finders_crm
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# --- JWT ---
# Production: at least 32 characters
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# --- CORS (browser Origin allowlist for the API) ---
# Primary frontend URL (no trailing slash)
FRONTEND_URL=http://localhost:3000
# Extra origins, comma-separated (custom domains, preview deploys, etc.)
# ALLOWED_ORIGINS=https://app.example.com,https://preview-abc.vercel.app
# On Railway, https://*.up.railway.app is allowed automatically when RAILWAY_ENVIRONMENT is set.

# --- Persistent uploads (logos, property images, documents) ---
# Local default is under the project; production often uses a mounted volume.
# DATA_DIR=/data

# --- Server ---
PORT=10000
HOST=0.0.0.0
NODE_ENV=development

# --- SMTP (optional; app can also read EMAIL_* aliases) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
